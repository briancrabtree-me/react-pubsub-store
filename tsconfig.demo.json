{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "react-pubsub-store": ["./src/index.ts"],
      "react-pubsub-store/*": ["./src/*"]
    }
  },
  "include": ["demo/**/*.ts", "demo/**/*.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
